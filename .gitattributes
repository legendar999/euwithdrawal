# Normalise line endings: the repo stores LF (modules run on Linux servers).
* text=auto eol=lf

*.png binary
*.jpg binary
*.gif binary

# Dev-only files: kept in the repo, excluded from the distributable zip
# (git archive). The Addons package must contain only shippable module files.
CLAUDE.md export-ignore
.gitignore export-ignore
.gitattributes export-ignore
